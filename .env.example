# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- PayPal ----
# Use "sandbox" while testing, switch to "live" for production.
PAYPAL_ENV=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Billing plans for each paid tier. Create once per environment via PayPal
# REST API or the PayPal dashboard. Pro fall-back uses PAYPAL_PLAN_ID for
# backwards compatibility with v1.
PAYPAL_STARTER_PLAN_ID=P-XXXXXXXXXXXXXXX
PAYPAL_PRO_PLAN_ID=P-XXXXXXXXXXXXXXX
PAYPAL_BUSINESS_PLAN_ID=P-XXXXXXXXXXXXXXX
PAYPAL_PLAN_ID=P-XXXXXXXXXXXXXXX

# Webhook ID for signature verification (created per-environment)
PAYPAL_WEBHOOK_ID=YOUR-WEBHOOK-ID

# ---- Email (Resend) ----
# Required for sending invoices, reminders and team invites.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=invoices@yourdomain.com

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
