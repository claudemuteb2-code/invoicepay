# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- PayPal ----
# Use "sandbox" while testing, switch to "live" for production.
PAYPAL_ENV=sandbox
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Billing plan for the Pro subscription (create once in the PayPal dashboard)
PAYPAL_PLAN_ID=P-XXXXXXXXXXXXXXX

# Webhook ID for signature verification (created per-environment)
PAYPAL_WEBHOOK_ID=YOUR-WEBHOOK-ID

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
